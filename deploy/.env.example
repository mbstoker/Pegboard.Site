# IONOS FTP deploy credentials for Pegboard.Site
# -------------------------------------------------
# Copy this file to  deploy/.env  and fill in the real values.
# deploy/.env is gitignored - it must NEVER be committed.
#
# Find these in the IONOS control panel under Hosting > the site >
# "SFTP & SSH" / "FTP access" (or the FileZilla details you already use).
#
# PROTOCOL: use "ftps" for explicit FTPS over TLS (recommended, IONOS supports it),
#           "ftp" for plain FTP, or "sftp" for SSH file transfer if enabled.
# PATH:     the remote web-root directory the files land in (what you point
#           FileZilla at). Often "/" or something like "/site" - match exactly
#           what you use today.

# --- Staging target (deployed + smoke-checked first) ---
FTP_STAGING_PROTOCOL=ftps
FTP_STAGING_HOST=
FTP_STAGING_USER=
FTP_STAGING_PASS=
FTP_STAGING_PATH=/
FTP_STAGING_URL=

# --- Production target (www.epegboard.com) ---
FTP_PROD_PROTOCOL=ftps
FTP_PROD_HOST=
FTP_PROD_USER=
FTP_PROD_PASS=
FTP_PROD_PATH=/
FTP_PROD_URL=https://www.epegboard.com
