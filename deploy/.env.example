# IONOS FTP deploy credentials for Pegboard.Site
# -------------------------------------------------
# Copy this file to  deploy/.env  and fill in the real values.
# deploy/.env is gitignored - it must NEVER be committed.
#
# Find these in the IONOS control panel under Hosting > the site >
# "SFTP & SSH" / "FTP access" (the same details you use in FileZilla).
#
# PROTOCOL:
#   ftps           = explicit FTPS over TLS on port 21 (IONOS default - recommended)
#   ftps-implicit  = implicit FTPS on port 990
#   ftp            = plain FTP (no encryption)
#   sftp           = SSH file transfer (port 22), if enabled
# PORT: usually 21 for ftps/ftp. Leave blank to use the protocol default.
# PATH: the remote web-root directory files land in (what FileZilla points at).
#       Match exactly what you use today - often "/" or e.g. "/site".

# --- Staging target (deployed + smoke-checked first) ---
FTP_STAGING_PROTOCOL=ftps
FTP_STAGING_HOST=
FTP_STAGING_PORT=21
FTP_STAGING_USER=
FTP_STAGING_PASS=
FTP_STAGING_PATH=/
FTP_STAGING_URL=

# --- Production target (www.epegboard.com) ---
FTP_PROD_PROTOCOL=ftps
FTP_PROD_HOST=
FTP_PROD_PORT=21
FTP_PROD_USER=
FTP_PROD_PASS=
FTP_PROD_PATH=/
FTP_PROD_URL=https://www.epegboard.com
