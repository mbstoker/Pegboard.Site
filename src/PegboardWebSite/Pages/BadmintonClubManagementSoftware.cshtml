@page "/badminton-club-management-software"
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Badminton club management software";
    ViewData["Description"] = "ePegboard is badminton club management and court scheduling software: smart game picking, fair balanced games, live player ratings, attendance and payments, handicap competitions and league-team selection. Free for 60 days.";
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>Badminton club management software</span></div>
      <h1 style="margin-top:10px">Badminton club management software</h1>
      <p class="lede">ePegboard is all-in-one badminton club management and court scheduling software. It runs fair club nights with automatically balanced games, tracks player ratings, handles attendance and payments, and runs handicap competitions and league teams - all in one place, in any browser.</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank" rel="noopener">Start Free Trial</a>
        <a class="btn btn-ghost btn-lg" href="https://play.epegboard.com/instant-demo" target="_blank" rel="noopener">See it in action</a>
      </div>
      <p class="trust"><span class="dot">&bull;</span> Free for 60 days &nbsp; <span class="dot">&bull;</span> No card details &nbsp; <span class="dot">&bull;</span> No install</p>
    </div>
  </div>
</section>

<!-- WHAT IT DOES: maps search language to features -->
<section style="padding-top:54px">
  <div class="wrap">
    <div class="section-head center">
      <span class="eyebrow">What it does</span>
      <h2>Everything a badminton club needs to run</h2>
      <p>One system for the four jobs clubs ask us for - on a single, trustworthy player rating.</p>
    </div>
    <div class="hub-grid">

      <a class="feat-card" href="/features/club-nights">
        <div class="feat-body">
          <h4>Court scheduling &amp; game picking</h4>
          <p>Smart game selection keeps every court busy with balanced, varied games matched on player level, rest time and who has played whom - and shows why each game was picked.</p>
          <span class="feat-learn">Club night software <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

      <a class="feat-card" href="/features/club-management">
        <div class="feat-body">
          <h4>Club administration &amp; reports</h4>
          <p>Attendance trends, payment tracking, member records and one-click CSV exports - the admin handled, so you spend less time on the spreadsheet and more time playing.</p>
          <span class="feat-learn">Club management <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

      <a class="feat-card" href="/features/competitions">
        <div class="feat-body">
          <h4>Tournament &amp; competition software</h4>
          <p>Run handicap doubles tournaments without spreadsheets - balanced pairs, group stages, knockout rounds and live standings, with handicaps calculated automatically.</p>
          <span class="feat-learn">Competitions <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

      <a class="feat-card" href="/features/league-team-support">
        <div class="feat-body">
          <h4>League team selection</h4>
          <p>Find the doubles partnerships that actually work from real club-night data, and pick league teams on evidence rather than hunches.</p>
          <span class="feat-learn">League team support <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- WHO IT IS FOR -->
<section class="bg-soft">
  <div class="wrap">
    <div class="section-head center">
      <span class="eyebrow">Who it is for</span>
      <h2>Built for badminton clubs of every size</h2>
      <p>From a single weekly club night to busy multi-court clubs running leagues and tournaments. ePegboard works on a tablet or laptop at the desk, with no software to install and nothing to configure before your first session.</p>
    </div>
    <div class="stats">
      <div class="stat"><div class="num">33,000+</div><div class="lbl">games played</div></div>
      <div class="stat"><div class="num">1,100+</div><div class="lbl">club sessions run</div></div>
      <div class="stat"><div class="num">2,000+</div><div class="lbl">players rated</div></div>
    </div>
  </div>
</section>

<!-- ENGINE THREAD -->
<section style="padding:48px 0">
  <div class="wrap">
    <div class="engine-strip">
      <div class="es-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M21 7v6h-6"/></svg></div>
      <div class="es-txt">
        <h3>One rating system, the whole platform</h3>
        <p>Ratings reflect how players perform against expectation, not just who won, and update after every game. The same number powers game picking, tournament handicaps and team selection - so everything stays consistent and current.</p>
      </div>
      <a class="btn btn-ghost" style="background:#fff" href="/features">See all features</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Try ePegboard free for 60 days</h2>
    <p>No subscription. No card details. Just smarter club nights.</p>
    <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank" rel="noopener">Sign up at play.epegboard.com</a>
    <p class="fine">Tablet or laptop-sized screens recommended for the best experience. Questions first? See the <a href="/faq">FAQ</a> or <a href="/Contact">get in touch</a>.</p>
  </div>
</section>

