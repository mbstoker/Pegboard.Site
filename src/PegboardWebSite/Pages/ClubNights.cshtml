@page "/features/club-nights"
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Run better club nights";
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <a href="/features">Features</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>Club Nights</span></div>
      <h1 style="margin-top:10px">Your club night, perfectly run</h1>
      <p class="lede">Smart game selection, fairness tracking and live stats - so courts stay full, games stay balanced, and the whole room can see why.</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank">Start Free Trial</a>
        <a class="btn btn-ghost btn-lg" href="#features">See the features</a>
      </div>
      <div class="pill-row">
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Smart game picking</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Pick explanations</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Fairness tracking</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Live stats &amp; ratings</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Audio announcements</span>
      </div>
    </div>
  </div>
</section>

<!-- TRANSFORM BAND: pegboard -> platform montage -->
<section class="bg-soft" style="padding:50px 0">
  <div class="wrap">
    <div class="section-head center" style="margin-bottom:34px">
      <h2 style="font-size:1.9rem">From a wooden pegboard to a whole club platform</h2>
      <p>Everything the manual board did - and the things it never could - running in any browser, no install.</p>
    </div>
    <div class="transform">
      <div class="tf-before">
        <img src="/img/wooden-pegboard.png" alt="A traditional wooden pegboard with named clothes pegs on numbered courts">
        <div class="tf-cap">The old way</div>
      </div>
      <div class="tf-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h16M14 6l6 6-6 6"/></svg></div>
      <div class="tf-after">
        <div class="tf-tile"><img src="/img/session-board.png" alt="Live club-night session"><span class="tl">Club nights</span></div>
        <div class="tf-tile"><img src="/img/standings-card.png" alt="Competition standings"><span class="tl">Competitions</span></div>
        <div class="tf-tile"><img src="/img/ratings.png" alt="Player rating trend" style="object-position:center"><span class="tl">Ratings</span></div>
        <div class="tf-tile"><img src="/img/partnerships-card.png" alt="Partnership analytics"><span class="tl">League teams</span></div>
        <div class="tf-tile wide"><img src="/img/site-attendee-stats.png" alt="Live attendee leaderboard - win percentage and rating change through the night"><span class="tl">Live stats players love</span></div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section id="features">
  <div class="wrap">

    <!-- Smart picking (real) -->
    <div class="showcase" style="margin-bottom:64px">
      <div class="copy">
        <div class="step-eyebrow">Smart game picking</div>
        <h3>Balanced games, picked for you</h3>
        <p>Open the app in a browser and go. ePegboard keeps every court busy with games matched on player level, rest time and who has played whom - and you can step in and adjust any time.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Less waiting, fuller courts</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Balanced, varied games all night</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Full operator control when you want it</li>
        </ul>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com</span></div>
        <img src="/img/session-board.png" alt="The live session pegboard - four courts running with waiting members">
      </div>
    </div>

    <!-- Add players (real) -->
    <div class="showcase flip" style="margin-bottom:64px">
      <div class="copy">
        <div class="step-eyebrow">Sign-in</div>
        <h3>Add players as they arrive</h3>
        <p>Sign players in in seconds - regulars, drop-ins and last-minute changes. Start typing a name, or tap a face from the photo gallery so newcomers can find their partners quickly.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com</span></div>
        <img src="/img/add-players.png" alt="Player sign-in with a photo gallery of members">
      </div>
    </div>

    <!-- Pick explanations -->
    <div class="showcase stack" style="margin-bottom:64px">
      <div class="copy">
        <div class="step-eyebrow">Pick explanations</div>
        <h3>Everyone can see why</h3>
        <p>ePegboard shows exactly why each game was picked - who was waiting longest, how the levels balance. No more "the system got it wrong" debates without the evidence in front of you.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com</span></div>
        <img src="/img/pick-explanation.png" asp-append-version="true" alt="Pick explanation - the suggested game, picked as the best of the candidates considered, with the reasons why">
      </div>
    </div>

    <!-- Live stats (real) -->
    <div class="showcase flip" style="margin-bottom:64px">
      <div class="copy">
        <div class="step-eyebrow">Stats &amp; fairness</div>
        <h3>Live stats the whole room can see</h3>
        <p>Players follow their win rate, rating change and match history as the night unfolds - and fairness is on show for everyone, so court time feels even. Great for keeping competitive clubs engaged.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Win percentage and rating change, live</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Match history for every attendee</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Fairness visible mid-session</li>
        </ul>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com</span></div>
        <img src="/img/site-attendee-stats.png" alt="Attendee stats - rankings, win percentage and rating changes">
      </div>
    </div>

    <!-- Announce (real) -->
    <div class="showcase">
      <div class="copy">
        <div class="step-eyebrow">Announce &amp; play</div>
        <h3>Games on screen, or called out loud</h3>
        <p>Game assignments show clearly on a shared screen so everyone knows where to go. Connect a speaker and ePegboard can announce the next games and players out loud - no shouting across the hall.</p>
      </div>
      <div class="shot" style="max-width:420px;margin:0 auto">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com</span></div>
        <img src="/img/session-board.png" alt="A court assignment shown clearly on screen">
      </div>
    </div>
  </div>
</section>

<!-- ENGINE THREAD (ratings) -->
<section class="bg-soft" style="padding:48px 0">
  <div class="wrap">
    <div class="engine-strip">
      <div class="es-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M21 7v6h-6"/></svg></div>
      <div class="es-txt">
        <h3>Ratings you can trust</h3>
        <p>Smart picking runs on a rating that reflects how players actually perform - stronger opponents are worth more, narrow defeats hurt less, and it updates after every game. The same ratings power tournaments and team selection.</p>
      </div>
      <a class="btn btn-ghost" style="background:#fff" href="/features/league-team-support">See team insights</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Run your next club night on ePegboard</h2>
    <p>Free for 60 days. No card details. Runs in any browser.</p>
    <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank">Start Free Trial</a>
    <p class="fine">Tablet or laptop-sized screens recommended for the best experience.</p>
  </div>
</section>

<!-- FOOTER -->
