@page "/features/competitions"
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Competitions and tournaments";
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <a href="/features">Features</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>Competitions</span></div>
      <h1 style="margin-top:10px">Run handicap tournaments without the spreadsheet</h1>
      <p class="lede">Create balanced internal tournaments in minutes - balanced doubles pairs, group stages and knockout rounds, with handicaps calculated automatically.</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank">Start Free Trial</a>
        <a class="btn btn-ghost btn-lg" href="#workflow">See the workflow</a>
      </div>
      <div class="pill-row">
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Automatic handicap calculations</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Balanced pair generation</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Group stages</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Knockout rounds</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Live standings</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Match result tracking</span>
      </div>
    </div>
  </div>
</section>

<!-- WORKFLOW -->
<section id="workflow">
  <div class="wrap">
    <div class="section-head center">
      <span class="eyebrow">The complete workflow</span>
      <h2>From idea to trophy, all in the app</h2>
      <p>Everything a club tournament needs - set up, pairs, groups, fixtures and results - in one place.</p>
    </div>

    <!-- 1 -->
    <div class="showcase">
      <div class="copy">
        <div class="step-eyebrow"><span class="wf-num">1</span> Create</div>
        <h3>Start a competition in minutes</h3>
        <p>Set up a handicap doubles tournament - group stages, knockout, or both - give it a date, and you are ready to add players. Run several competitions side by side.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/competitions</span></div>
        <img src="/img/Tournaments.png" alt="Competitions list - handicap doubles tournaments in progress">
      </div>
    </div>

    <!-- 2 -->
    <div class="showcase flip">
      <div class="copy">
        <div class="step-eyebrow"><span class="wf-num">2</span> Select players</div>
        <h3>Pick your entrants from the club</h3>
        <p>Choose entrants straight from your membership list. Player ratings are pulled in automatically and used when generating balanced pairs - no manual seeding.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/competitions</span></div>
        <img src="/img/comp-select-players.png" alt="Select players step - pick entrants from the membership list, with ratings pulled in automatically">
      </div>
    </div>

    <!-- 3 -->
    <div class="showcase">
      <div class="copy">
        <div class="step-eyebrow"><span class="wf-num">3</span> Generate pairs</div>
        <h3>Balanced doubles pairs, generated for you</h3>
        <p>One click builds pairs designed for competitive, enjoyable games rather than runaway mismatches. This is the step that saves organisers the most time.</p>
        <div class="callout">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6z"/></svg>
          <p><b>You stay in control.</b> Lock a pair you want to keep, swap a player, or block a pairing entirely - then regenerate around your choices.</p>
        </div>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/competitions</span></div>
        <img src="/img/comp-generate-pairs.png" alt="Generated doubles pairs with player ratings and a combined pair rating for each pairing">
      </div>
    </div>

    <!-- 4 -->
    <div class="showcase flip">
      <div class="copy">
        <div class="step-eyebrow"><span class="wf-num">4</span> Build groups</div>
        <h3>Spread the strong pairs across groups</h3>
        <p>ePegboard distributes seeded pairs so every group is balanced and competitive - the fiddly job most clubs currently do by hand on a whiteboard.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/competitions</span></div>
        <img src="/img/comp-build-groups.png" alt="Seeded pairs spread evenly across balanced groups, each shown with its pair rating">
      </div>
    </div>

    <!-- 5 -->
    <div class="showcase">
      <div class="copy">
        <div class="step-eyebrow"><span class="wf-num">5</span> Run it</div>
        <h3>Fixtures and handicaps, done automatically</h3>
        <p>Round-robin fixtures are generated for each group, with handicap starts (the +5, +3 you see beside each pair still to play) calculated and applied for you. Enter scores as games finish and the standings update live.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/competitions</span></div>
        <img src="/img/comp-group-fixtures.png" alt="Group fixtures with handicap starts - some matches scored, others still to play showing their +5 / +3 head starts">
      </div>
    </div>

    <!-- 6 -->
    <div class="showcase flip">
      <div class="copy">
        <div class="step-eyebrow"><span class="wf-num">6</span> Live standings</div>
        <h3>Standings update as the scores go in</h3>
        <p>Points, games won and point difference, live for the whole room. Everyone can see who is through and what is still to play, right up to the knockout rounds.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/competitions</span></div>
        <img src="/img/standings.png" alt="Live competition standings - group table with points, games won and point difference">
      </div>
    </div>

    <!-- 7 -->
    <div class="showcase">
      <div class="copy">
        <div class="step-eyebrow"><span class="wf-num">7</span> Knockout</div>
        <h3>Into the knockout, automatically</h3>
        <p>When the groups finish, ePegboard seeds the knockout from the standings and builds the bracket - semi-finals through to the final, handicaps still applied. Enter results and it crowns your winner.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/competitions</span></div>
        <img src="/img/comp-knockout.png" alt="Knockout bracket - semi-finals and final with scores, and the tournament winner crowned">
      </div>
    </div>
  </div>
</section>

<!-- MORE FORMATS -->
<section style="padding-top:0">
  <div class="wrap">
    <div class="callout" style="max-width:780px;margin:0 auto;align-items:center">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 2"/></svg>
      <p><b>Handicap doubles is our first tournament format</b> - the one clubs ask for most. Singles and team-event formats are on the roadmap and coming next.</p>
    </div>
  </div>
</section>

<!-- ENGINE THREAD -->
<section class="bg-soft" style="padding:48px 0">
  <div class="wrap">
    <div class="engine-strip">
      <div class="es-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M21 7v6h-6"/></svg></div>
      <div class="es-txt">
        <h3>Handicaps you can trust</h3>
        <p>Handicaps are calculated from the same rating system that powers your club nights - so they reflect how players actually perform, and stay current as results come in.</p>
      </div>
      <a class="btn btn-ghost" style="background:#fff" href="/features/club-nights">How ratings work</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Run your next tournament on ePegboard</h2>
    <p>Set it up in minutes, free for 60 days. No card details.</p>
    <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank">Start Free Trial</a>
    <p class="fine">Tablet or laptop-sized screens recommended for the best experience.</p>
  </div>
</section>

<!-- FOOTER -->
