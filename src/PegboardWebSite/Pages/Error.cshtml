@page
@model ErrorModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="py-4" style="max-width:640px">
    <h1 class="h3">Something went wrong</h1>
    <p class="fs-5 text-muted">Sorry - the page hit an unexpected error. That's on us, not you.</p>

    <p>A few things you can try:</p>
    <ul class="fs-6">
        <li>Head back to the <a asp-page="/Index">home page</a> and try again.</li>
        <li>Looking for the app? It runs at <a href="https://play.epegboard.com" target="_blank" rel="noopener">play.epegboard.com</a>.</li>
        <li>Still stuck? Email <a href="mailto:support@epegboard.com">support@epegboard.com</a> and we'll sort it out.</li>
    </ul>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted mt-4" style="font-size:.9rem">
            If you get in touch, quoting this reference helps us track down what happened:<br />
            <code>@Model.RequestId</code>
        </p>
    }
</div>
