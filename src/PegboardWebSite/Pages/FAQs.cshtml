@page "/faq"
@model FAQsModel
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "FAQ - badminton club software";
    ViewData["Description"] = "Answers to common questions about ePegboard badminton club software: how it is free, setup, devices, how player ratings work, and getting your data out.";

    var px = PegboardWebSite.Services.CurrencyResolver.Get(ViewContext.HttpContext);

    // FAQPage structured data - mirrors the visible Q&A below (plain-text answers).
    // Kept canonical in GBP (crawler-facing, mostly-UK search audience); only the
    // visible HTML answers below switch currency per the visitor's choice.
    var faqPairs = new (string Q, string A)[]
    {
        ("Is it really free?", "Yes. The full club-night workflow is free for every club - the smart picker, live ratings, scoring, payments, attendance, tournaments, history and reports. It is the complete app, not a cut-down demo, and there is no card to enter. It suits the vast majority of clubs, and it stays free."),
        ("Do we need to install anything?", "No. The web app runs in any modern browser - just sign in at play.epegboard.com. There is also a Windows desktop app for venues with unreliable internet, but most clubs never need it."),
        ("How long does it take to set up?", "You can be running your first session in minutes. Sign in, add players as they arrive, and let ePegboard build balanced games. There is nothing to configure before your first night."),
        ("What devices does it work on?", "The session display is designed for a tablet or laptop at the desk. Players can check their own profile, rating and match history on their phone. A larger screen for the courts is optional but works well."),
        ("Is there a catch, or a paywall later?", "No. There is no card on file and nothing is charged automatically. The club-night workflow is free for good. If your club values ePegboard you can chip in as a community supporter to help cover running costs, but that is entirely optional and never unlocks anything. For a very large or multi-site club, a league or a one-off competition, get in touch and we will help."),
        ("What is the difference between the web app and the desktop app?", "The web app runs in any browser on any device, needs no install, and is where new features land first. The Windows desktop app runs fully offline - the right choice if your venue has unreliable internet - and costs GBP 60 per year per club after a 60-day free trial."),
        ("Is the desktop app still supported?", "Yes. Clubs that rely on it for offline venues can keep using it. New development focuses on the web app, so that is where the latest picking, competitions and analytics features appear first."),
        ("How does the rating system work?", "Every player has a rating that reflects how they perform against expectation - not just who won. A narrow loss to a stronger pair can still move you up; a heavy loss to weaker players costs more. Ratings update after every game and power smart picking, handicap tournaments, partnership analytics and league selection."),
        ("Will it actually make our games fairer?", "That is the whole point. ePegboard balances games on current form, tracks who has been sitting out, and keeps an eye on court-time fairness across the night - so stronger and newer players both get good games. It also shows exactly why each game was picked."),
        ("Can players see their own stats?", "Yes. Each player has a profile - rating, win rate and recent match history - that they can check on their phone. Many clubs find the live ratings become a talking point in their own right."),
        ("Can we get our data out?", "Yes. Your club data is yours. Reports - attendance, payments, members and more - can be exported to CSV whenever you need them, so the numbers are never locked in."),
        ("Can more than one person run our club?", "Yes. You can invite other people to help run your club by email and give each one a role - owner, admin or standard. Owners and admins can both start sessions, manage members and change settings. You can change a role or remove access whenever you need to."),
        ("We came from the desktop Pegboard - can we bring our history across?", "Yes. Clubs moving from the Windows desktop app can carry their members and playing history into the web app, so your ratings and records continue rather than starting from scratch. Get in touch and we will help with the move.")
    };
    var faqItems = new List<object>();
    foreach (var f in faqPairs)
    {
        faqItems.Add(new Dictionary<string, object>
        {
            ["@type"] = "Question",
            ["name"] = f.Q,
            ["acceptedAnswer"] = new Dictionary<string, object>
            {
                ["@type"] = "Answer",
                ["text"] = f.A
            }
        });
    }
    var faqJsonLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "FAQPage",
        ["mainEntity"] = faqItems
    });
}

@section Head {
    <script type="application/ld+json">@Html.Raw(faqJsonLd)</script>
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>FAQ</span></div>
      <h1 style="margin-top:10px">Frequently asked questions</h1>
      <p class="lede">The things club organisers ask us most - getting started, what it costs, how the ratings work, and what happens to your data.</p>
    </div>
  </div>
</section>

<!-- FAQ -->
<section style="padding-top:50px">
  <div class="wrap">
    <div class="faq-wrap">

      <div class="faq-cat">Getting started</div>

      <details class="faq-item">
        <summary>Is it really free? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>Yes. The full club-night workflow is free for every club - the smart picker, live ratings, scoring, payments, attendance, tournaments, history and reports. It is the complete app, not a cut-down demo, and there is no card to enter. It suits the vast majority of clubs, and it stays free.</p></div>
      </details>

      <details class="faq-item">
        <summary>Do we need to install anything? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>No. The web app runs in any modern browser - just sign in at <a href="https://play.epegboard.com" target="_blank">play.epegboard.com</a> and you are away. There is also a Windows desktop app for venues with unreliable internet, but most clubs never need it.</p></div>
      </details>

      <details class="faq-item">
        <summary>How long does it take to set up? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>You can be running your first session in minutes. Sign in, add players as they arrive - regulars, drop-ins and last-minute changes - and let ePegboard build balanced games. There is nothing to configure before your first night.</p></div>
      </details>

      <details class="faq-item">
        <summary>What devices does it work on? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>The session display is designed for a tablet or laptop at the desk - a screen everyone can gather around. Players can check their own profile, rating and match history on their phone. A larger screen for the courts is optional but works well.</p></div>
      </details>

      <div class="faq-cat">Pricing &amp; plans</div>

      <details class="faq-item">
        <summary>Is there a catch, or a paywall later? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>No. There is no card on file and nothing is charged automatically. The club-night workflow is free for good. If your club values ePegboard you can chip in as a community supporter to help cover running costs, but that is entirely optional and never unlocks anything. For a very large or multi-site club, a league or a one-off competition, <a href="mailto:sales@epegboard.com?subject=ePegboard%20enquiry">get in touch</a> and we will help. Full details are on the <a href="/pricing">Pricing</a> page.</p></div>
      </details>

      <details class="faq-item">
        <summary>What is the difference between the web app and the desktop app? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>The web app runs in any browser on any device, needs no install, and is where new features land first. The Windows desktop app runs fully offline - the right choice if your venue has unreliable internet - and costs @(px.Symbol)@px.DesktopYear per year per club after a 60-day free trial.</p></div>
      </details>

      <details class="faq-item">
        <summary>Is the desktop app still supported? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>Yes. Clubs that rely on it for offline venues can keep using it. New development focuses on the web app, so that is where the latest picking, competitions and analytics features appear first.</p></div>
      </details>

      <div class="faq-cat">How it works</div>

      <details class="faq-item">
        <summary>How does the rating system work? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>Every player has a rating that reflects how they perform against expectation - not just who won. A narrow loss to a stronger pair can still move you up; a heavy loss to weaker players costs more. Ratings update after every game, and the same number quietly powers smart picking, handicap tournaments, partnership analytics and league selection. <a href="https://docs.epegboard.com/ratings/overview/" target="_blank" rel="noopener">See how ratings work</a> for the full detail, including the exact formula.</p></div>
      </details>

      <details class="faq-item">
        <summary>Will it actually make our games fairer? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>That is the whole point. ePegboard balances games on current form, tracks who has been sitting out, and keeps an eye on court-time fairness across the night - so stronger and newer players both get good games, and nobody is stuck waiting. It also shows exactly why each game was picked. <a href="https://docs.epegboard.com/club-nights/the-picker/" target="_blank" rel="noopener">More on how the picker chooses games</a>.</p></div>
      </details>

      <details class="faq-item">
        <summary>Can players see their own stats? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>Yes. Each player has a profile - rating, win rate and recent match history - that they can check on their phone. Many clubs find the live ratings become a talking point in their own right.</p></div>
      </details>

      <div class="faq-cat">Your club &amp; your data</div>

      <details class="faq-item">
        <summary>Can we get our data out? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>Yes. Your club's data is yours. Reports - attendance, payments, members and more - can be exported to CSV whenever you need them, so the numbers are never locked in.</p></div>
      </details>

      <details class="faq-item">
        <summary>Can more than one person run our club? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>Yes. You can invite other people to help run your club by email and give each one a role - owner, admin or standard. Owners and admins can both start sessions, manage members and change settings, so a club night never depends on one person being in the room. You can change someone's role or remove their access whenever you need to.</p></div>
      </details>

      <details class="faq-item">
        <summary>We came from the desktop Pegboard - can we bring our history across? <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
        <div class="faq-a"><p>Yes. Clubs moving from the Windows desktop app can carry their members and playing history into the web app, so your ratings and records continue rather than starting from scratch. Get in touch and we will help with the move. <a href="https://docs.epegboard.com/how-to/move-from-desktop/" target="_blank" rel="noopener">See the migration guide</a>.</p></div>
      </details>

    </div>
  </div>
</section>

<!-- STILL HAVE A QUESTION -->
