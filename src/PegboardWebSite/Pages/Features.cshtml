@page
@model FeaturesModel
@{
    ViewData["Title"] = "Features - web app";
}

@using System.Net.Mime;

<section class="features-header bg-light py-5">
    <div class="container text-center">
        <h1 class="display-4">Packed With Powerful Features</h1>
        <p class="lead">Everything you need to run club nights smoothly and manage your players effectively.</p>
        <p class="text-muted" style="font-size: 1rem;">
            Runs in any browser on any device at <a href="https://play.epegboard.com" target="_blank" rel="noopener">play.epegboard.com</a>. Tablet or laptop-sized screens recommended for the best experience.
        </p>
        <a asp-page="/FeaturesDesktop" class="btn btn-outline-secondary btn-sm mt-2">
            💻 Looking for desktop app features? →
        </a>
    </div>
</section>

<section class="feature-section py-5">
    <div class="container">

        <!-- Club Night Dashboard (centered) -->
        <div class="text-center mb-5">
            <h2 class="mb-4">Club Night Dashboard</h2>
            <a href="/images/site-dashboard.png" target="_blank">
                <img src="/images/site-dashboard.png" class="img-fluid rounded mb-4 shadow-sm" style="max-width: 95%; height: auto;" alt="Mid-session dashboard - 4 courts running">
            </a>
            <div class="row justify-content-center">
                <div class="col-lg-10 col-xl-8">
                    <div class="mb-4">
                        <div class="d-flex align-items-start mb-4 fs-5">
                            <i class="bi bi-layout-text-sidebar me-3 fs-4 text-primary flex-shrink-0"></i>
                            <span>One screen shows everything: courts, queue, game results, and live stats.</span>
                        </div>
                        <div class="d-flex align-items-start mb-4 fs-5">
                            <i class="bi bi-tablet-landscape me-3 fs-4 text-primary flex-shrink-0"></i>
                            <span>Works on any browser, any device - tablet or laptop-sized screens recommended for the best experience.</span>
                        </div>
                        <div class="d-flex align-items-start mb-4 fs-5">
                            <i class="bi bi-hand-index-thumb me-3 fs-4 text-primary flex-shrink-0"></i>
                            <span>Drag-and-drop, touch-friendly UI - non-technical players can pick up the operator role quickly.</span>
                        </div>
                        <div class="d-flex align-items-start mb-4 fs-5">
                            <i class="bi bi-easel3 me-3 fs-4 text-primary flex-shrink-0"></i>
                            <span>Organised similarly to a traditional pegboard so the model is familiar to anyone who's used one.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Zigzag Start -->
        @{
            var features = new[]
            {
        new { Img="/images/site-checkin-dropdown.png", Title="Managing Attendees", List = new[]{"Tap the check-in field and the full member list opens immediately - or start typing to narrow down", "Photos help newcomers identify partners quickly", "Mark players unavailable to avoid being picked mid-break"}, Clickable = true},
        new { Img="/images/site-pick-and-start.png", Title="Pick and Start", List = new[]{"Instantly fill a court with a smart, balanced game", "Designed for fast-paced clubs where players can jump straight on court", "Combines skill, fairness, and variation in real-time", "Editable/cancelable game suggestions before play"}, Clickable = true},
        new { Img="/images/site-prep-panel.png", Title="Prepare Next Game", List = new[]{"Choose game before a court is available", "Auto-pick, manual pick or pick some and let ePegboard pick the rest", "Drag and drop from queue into the prep area", "Control and flexibility with AI assistance"}, Clickable = true},
        new { Img="/images/site-session-settings.png", Title="Support for Traditional Picking", List = new[]{"Configurable to pick first from queue and fill from next N players", "Per-session settings - tweak rules just for tonight, or save multiple reusable profiles", "Respect traditional usage while using modern tools"}, Clickable = true},
        new { Img="/images/balanced-elo.png", Title="Smart Game Picking", List = new[]{"ELO-style rating system for balanced games", "Expected scores shown for every matchup", "Style compatibility, fairness, queue rotation", "The most common complaint we heard was higher-rated players paired with weak partners - that's been the main driver of the picker work since"}, Clickable = false},
        new { Img="/images/site-pick-explainer.png", Title="Pick Explanations", List = new[]{"Players see exactly why each game was picked", "Cuts down on 'the algorithm got it wrong' arguments without evidence", "Per-pick scoring breakdown for the operator if they want to dig in"}, Clickable = true},
        new { Img="/images/site-attendee-stats.png", Title="Fairness Statistics", List = new[]{"Visible mid-session - rating change, win %, game count per attendee", "Players and operators can see balance in real time", "No more 'I've been sat off ages' arguments without data"}, Clickable = true},
        new { Img="/images/site-score-entry.png", Title="Fast results capture", List = new[]{"Enter scores after the game to instantly update ratings and stats", "Can start another game before score entry to keep things moving", "Just fill in the losing team's score - the winning team's is automatically populated", "Large buttons + hot-zone chips for easy entry"}, Clickable = true},
        new { Img="/images/audio-announcements.png", Title="Smart Audio Announcements", List = new[]{"Built-in voice calls for games and courts", "Removes need for shouting or manual reminders"}, Clickable = false},
        new { Img="/images/site-completed-games.png", Title="Completed Games History", List = new[]{"Full list of every game with start/end time, winning + losing teams, score and par", "Per-court breakdown for the night", "Edit or void from the same view if a score went in wrong"}, Clickable = true},
        new { Img="/images/site-attendee-stats.png", Title="Real-time Stats and Ratings", List = new[]{"Track win %, rating changes and full match history per attendee", "Initial vs current rating with rating-change deltas in green / red", "Live leaderboard - engages players regardless of skill level"}, Clickable = true},
        new { Img="/images/site-attendance-trends.png", Title="Attendance Reports", List = new[]{"Built-in attendance reports - who's been coming, who's lapsing, who's new", "Status classification: Active / Lapsing / Dormant / New", "Useful for member-retention conversations and re-engagement"}, Clickable = true},
        new { Img="/images/site-payments.png", Title="Payment Tracking", List = new[]{"Track full or partial session payments per attendee", "Customise session cost by member type (Guest / Full / Trial)", "Live total due / paid / outstanding for the night", "CSV export and historical reporting"}, Clickable = true},
        new { Img="/images/site-members.png", Title="Member Management", List = new[]{"Contact details, photos, attendance stats, ratings - all in one place", "Filter by Active / Inactive / Show Deactivated", "Bulk import for quick setup; CSV export for backup", "Invite members to the app from the same page"}, Clickable = true},
        new { Img="/images/site-session-summary.png", Title="Session Analytics", List = new[]{"Cross-session view: attendance, games played, voids, status", "Filter by date range, profile, venue", "Drill into any past session for full results, payments and standings"}, Clickable = true},
        new { Img="/images/site-parallel-sessions.png", Title="Run Sessions in Parallel", List = new[]{"Two club nights at once? Run two live sessions side-by-side from the same club", "Each session has its own pegboard, scores, and stats - they don't interfere with each other", "Useful when a junior session overlaps with a senior session, or for satellite venues sharing a club"}, Clickable = true},
        new { Img="/images/site-member-profile.png", Title="Per Member Analytics", List = new[]{"Click any member to see their full history - sessions attended, games played, win %", "Rating progression chart shows improvement over time", "Best and worst partners surfaced from the data"}, Clickable = true},
            };
        }

        @for (int i = 0; i < features.Length; i++)
        {
            var feature = features[i];
            var reverse = i % 2 != 0;
            <div class="row align-items-center mb-5">
                <div class="col-md-6 @(reverse ? "order-md-2" : "")">
                    @if (feature.Clickable)
                    {
                        <a href="@feature.Img" target="_blank">
                            <img src="@feature.Img" class="img-fluid rounded mb-3 feature-img" alt="@feature.Title" />
                        </a>
                    }
                    else
                    {
                        <img src="@feature.Img" class="img-fluid rounded mb-3 feature-img" alt="@feature.Title" />
                    }
                </div>
                <div class="col-md-6">
                    <h3>@feature.Title</h3>
                    <ul>
                        @foreach (var item in feature.List)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</section>
<style>
  .feature-img {
    max-width: 100%;
    height: auto;
  }

  @@media only screen and (max-width: 576px) {
    .feature-img {
      max-width: 90%;
      margin-left: auto;
      margin-right: auto;
      display: block;
    }
  }
</style>

<section class="cta text-center py-5 bg-success text-white">
    <h2>Start your free 60-day trial today</h2>
    <p class="lead mb-3">Free for at least 60 days. No card details.</p>
    <a href="https://play.epegboard.com" target="_blank" rel="noopener" class="btn btn-light btn-lg mt-3">Sign Up at play.epegboard.com</a>
    <p class="mt-3 mb-0" style="font-size: 0.95rem; opacity: 0.9;">Tablet or laptop-sized screens recommended for the best experience.</p>
</section>
