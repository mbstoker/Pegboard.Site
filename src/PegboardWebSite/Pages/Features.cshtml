@page
@model FeaturesModel
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Badminton club software features";
    ViewData["Description"] = "Everything a badminton club needs in one place: smart game picking, club management and reports, handicap competitions and league-team analytics, all on one player rating system.";
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>Features</span></div>
      <h1 style="margin-top:10px">Everything a club night needs, in one place</h1>
      <p class="lede">Everything a badminton club needs - run better club nights, manage the club, run competitions and build league teams - all on one intelligent rating system.</p>
    </div>
  </div>
</section>

<!-- PILLAR CARDS -->
<section style="padding-top:54px">
  <div class="wrap">
    <div class="hub-grid">

      <a class="feat-card" id="club-nights" href="/features/club-nights">
        <div class="feat-thumb"><img src="/img/session-board.png" alt="Live session board preview"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z"/><path d="M3 12h18M12 3v18"/></svg></div>
          <h4>Run Better Club Nights</h4>
          <p>Smart game selection, fairness tracking and live stats - so courts stay full and games stay balanced.</p>
          <ul class="hub-feats"><li>Smart picking</li><li>Pick explanations</li><li>Fairness</li><li>Live stats &amp; ratings</li><li>Audio announcements</li></ul>
          <span class="feat-learn">Explore club nights <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

      <a class="feat-card" id="club-management" href="/features/club-management">
        <div class="feat-thumb"><img src="/img/attendance-trends.png" alt="Attendance trends - active, lapsing and dormant members" style="object-position:top center"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13A4 4 0 0 1 16 11"/></svg></div>
          <h4>Manage Your Club</h4>
          <p>Attendance, payments, members and the insights to keep your club growing - the running of the club, handled.</p>
          <ul class="hub-feats"><li>Attendance trends</li><li>Payments</li><li>Members</li><li>Reports &amp; CSV export</li></ul>
          <span class="feat-learn">Explore club management <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

      <a class="feat-card" id="competitions" href="/features/competitions">
        <div class="feat-thumb"><img src="/img/standings-card.png" alt="Live competition standings" style="object-fit:contain;object-position:center;background:#fff"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h8M12 17v4M6 4h12v4a6 6 0 0 1-12 0V4zM6 5H3v2a3 3 0 0 0 3 3M18 5h3v2a3 3 0 0 1-3 3"/></svg></div>
          <h4>Competitions &amp; Tournaments</h4>
          <p>Handicap tournaments without spreadsheets - balanced pairs, group stages and live standings, generated for you.</p>
          <ul class="hub-feats"><li>Handicap tournaments</li><li>Balanced pairs</li><li>Group stages</li><li>Knockout rounds</li><li>Live standings</li></ul>
          <span class="feat-learn">Explore competitions <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

      <a class="feat-card" id="league-team-support" href="/features/league-team-support">
        <div class="feat-thumb"><img src="/img/partnerships-card.png" alt="Partnership analytics - pairs and how they perform versus expectation" style="object-fit:contain;object-position:center;background:#fff"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18M7 14l4-4 3 3 5-6"/></svg></div>
          <h4>League Team Support</h4>
          <p>Build stronger teams from real club-night data - find the partnerships that work, then pick on evidence.</p>
          <ul class="hub-feats"><li>Partnership analytics</li><li>Player ratings</li><li>Fixed partnerships</li><li>Team selection</li></ul>
          <span class="feat-learn">Explore league team support <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- ENGINE THREAD -->
<section class="bg-soft" style="padding:48px 0">
  <div class="wrap">
    <div class="engine-strip">
      <div class="es-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M21 7v6h-6"/></svg></div>
      <div class="es-txt">
        <h3>One rating system runs all four</h3>
        <p>Ratings update from how players actually perform, then quietly power smart picking, handicaps, partnership analytics and team selection - so everything stays consistent.</p>
      </div>
      <a class="btn btn-ghost" style="background:#fff" href="https://docs.epegboard.com/ratings/overview/" target="_blank" rel="noopener">How ratings work</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Run your club on ePegboard, free</h2>
    <p>No subscription. No card details. Runs in any browser.</p>
    <div class="cta-actions">
      <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank">Sign up</a>
      <a class="btn btn-lg cta-demo" href="https://play.epegboard.com/instant-demo" target="_blank" rel="noopener">See it in action</a>
    </div>
    <p class="fine">Tablet or laptop-sized screens recommended for the best experience.</p>
  </div>
</section>

<!-- FOOTER -->
