@page
@model IndexModel
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Badminton club management software";
    ViewData["Description"] = "ePegboard is badminton club management and court scheduling software. Run fair club nights with automatically balanced games, live player ratings, attendance tracking and competitions. Free for clubs at play.epegboard.com.";

    var swJsonLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "SoftwareApplication",
        ["name"] = "ePegboard",
        ["applicationCategory"] = "BusinessApplication",
        ["applicationSubCategory"] = "Badminton club management software",
        ["operatingSystem"] = "Web browser",
        ["url"] = "https://www.epegboard.com",
        ["description"] = "Badminton club management and court scheduling software that runs fair club nights, automatically generates balanced games, tracks player ratings, manages attendance and payments, and runs handicap competitions and league-team selection.",
        ["offers"] = new Dictionary<string, object>
        {
            ["@type"] = "Offer",
            ["price"] = "0",
            ["priceCurrency"] = "GBP",
            ["description"] = "Free for clubs - the full club-night workflow at no cost, no card needed."
        },
        ["publisher"] = new Dictionary<string, object>
        {
            ["@type"] = "Organization",
            ["name"] = "MBS Software Limited"
        }
    });
}

@section Head {
    <script type="application/ld+json">@Html.Raw(swJsonLd)</script>
}

<!-- HERO: copy + tablet screenshot, four small feature cards beneath -->
<section class="hero" style="padding:0">
  <div class="wrap">
    <div class="hero-top">
      <div class="hero-copy">
        <span class="eyebrow">All-in-one badminton club software</span>
        <h1>Smarter club nights. <span class="accent">Fairer games.</span></h1>
        <p class="lede">ePegboard is all-in-one software for badminton clubs - run better club nights, tournaments and league teams, with data that keeps games balanced and helps clubs make better decisions.</p>
        <ul class="hero-bullets">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Balanced games, every session</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Hours of weekly admin saved</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Fairer nights, happier players</li>
        </ul>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank">Sign up</a>
          <a class="btn btn-ghost btn-lg" href="https://play.epegboard.com/instant-demo" target="_blank" rel="noopener">See it in action</a>
        </div>
        <p class="trust"><span class="dot">&bull;</span> Free for clubs &nbsp; <span class="dot">&bull;</span> No card details &nbsp; <span class="dot">&bull;</span> No install</p>
      </div>

      <div class="hero-visual">
        <div class="laptop">
          <div class="screen">
            <div class="browserbar">
              <span class="dots"><i></i><i></i><i></i></span>
              <span class="url"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg> play.epegboard.com</span>
            </div>
            <img src="/img/site-dashboard.png" alt="ePegboard live session dashboard - four courts running with waiting members">
          </div>
        </div>
        <div class="laptop-base"></div>

        <div class="float float-analytics">
          <div class="fc-label">League team insights</div>
          <div class="fc-pair"><span class="av f"></span><span class="av"></span> Priya &amp; Marcus</div>
          <div class="fc-stat"><span class="up"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M21 7v6h-6"/></svg> +185</span><small>vs expected</small></div>
        </div>

        <div class="phone">
          <div class="pscreen"><span class="notch"></span><img src="/img/phone-session.png" alt="A live club-night session running on a phone - courts, players and scores"></div>
        </div>
      </div>
    </div>

    <div class="feat-cards">
      <a class="feat-card" href="/features/club-nights">
        <div class="feat-thumb"><img src="/img/session-board.png" alt="Live session board preview"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z"/><path d="M3 12h18M12 3v18"/></svg></div>
          <h4>Run Better Club Nights</h4>
          <p>Smart game selection, fairness tracking and live ratings - courts stay full, games stay balanced.</p>
          <span class="feat-learn">Learn more <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a class="feat-card" href="/features/club-management">
        <div class="feat-thumb"><img src="/img/attendance-trends.png" alt="Attendance trends - active, lapsing and dormant members, and who to reach out to" style="object-position:top center"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13A4 4 0 0 1 16 11"/></svg></div>
          <h4>Manage Your Club</h4>
          <p>Attendance, payments, members and reports - the admin handled, so you spend less time on the spreadsheet.</p>
          <span class="feat-learn">Learn more <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a class="feat-card" href="/features/competitions">
        <div class="feat-thumb"><img src="/img/standings-card.png" alt="Live competition standings - group table with points, games won and point difference" style="object-fit:contain;object-position:center;background:#fff"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h8M12 17v4M6 4h12v4a6 6 0 0 1-12 0V4zM6 5H3v2a3 3 0 0 0 3 3M18 5h3v2a3 3 0 0 1-3 3"/></svg></div>
          <h4>Competitions &amp; Tournaments</h4>
          <p>Handicap tournaments without spreadsheets - balanced pairs, group stages and live standings, generated for you.</p>
          <span class="feat-learn">Learn more <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a class="feat-card" href="/features/league-team-support">
        <div class="feat-thumb"><img src="/img/partnerships-card.png" alt="Partnership analytics - pairs and how they perform versus expectation, with verdict and confidence" style="object-fit:contain;object-position:center;background:#fff"></div>
        <div class="feat-body">
          <div class="feat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18M7 14l4-4 3 3 5-6"/></svg></div>
          <h4>League Team Support</h4>
          <p>Build stronger teams from real club-night data - find the partnerships that work, then pick on evidence.</p>
          <span class="feat-learn">Learn more <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<section class="trust-strip" style="padding:0">
  <div class="wrap"><div class="row">
    <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg> Trusted by clubs across the UK &amp; Ireland</div>
    <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg> <span>1,100+ club sessions run</span></div>
    <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13A4 4 0 0 1 16 11"/></svg> Built for players and organisers</div>
    <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20z"/></svg> Runs free in any browser</div>
  </div></div>
</section>

<!-- ENGINE -->
<section class="engine">
  <div class="wrap engine-grid">
    <div>
      <span class="eyebrow">The engine underneath</span>
      <h2>One rating system. The whole platform.</h2>
      <p class="sub">Ratings change based on how players perform against expectation - not just who won. That single, trustworthy number quietly powers every part of ePegboard.</p>
      <ul class="drives">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Smart game picking</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Handicap tournaments</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Partnership analytics</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> League team selection</li>
      </ul>
    </div>
    <div class="rating-demo">
      <div class="rd-row"><span class="rd-label">Expected result</span><span class="rd-val">Lose by 8</span></div>
      <div class="rd-row"><span class="rd-label">Actual result</span><span class="rd-val">Lost by 2</span></div>
      <div class="rd-row"><span class="rd-label">Rating change</span><span class="rd-up"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg> Goes up</span></div>
      <p class="rd-note">A narrow loss to a stronger pair still moves you up. Win-loss alone never tells that story.</p>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section>
  <div class="wrap">
    <div class="section-head center"><span class="eyebrow">How it works</span><h2>From arrivals to results, in four steps</h2></div>
    <div class="steps">
      <div class="step"><div class="n">1</div><h4>Add players</h4><p>Sign players in as they arrive - regulars, drop-ins and last-minute changes. Start typing or tap a photo.</p></div>
      <div class="step"><div class="n">2</div><h4>Build the games</h4><p>ePegboard creates balanced games and shows exactly why each was picked.</p></div>
      <div class="step"><div class="n">3</div><h4>Announce and play</h4><p>Games show clearly on screen, with optional audio call-outs. Courts stay full.</p></div>
      <div class="step"><div class="n">4</div><h4>See the stats</h4><p>Players watch ratings, win rate and match history update live.</p></div>
    </div>
  </div>
</section>

