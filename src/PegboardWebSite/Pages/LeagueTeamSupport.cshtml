@page "/features/league-team-support"
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "League team support";
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <a href="/features">Features</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>League Team Support</span></div>
      <span class="eyebrow">League Team Support</span>
      <h1 style="margin-top:10px">Build stronger league teams</h1>
      <p class="lede">Use real club-night data to find the doubles pairings that actually work - and pick teams on evidence, not hunches.</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank">Start Free Trial</a>
        <a class="btn btn-ghost btn-lg" href="#how">See how it works</a>
      </div>
      <div class="pill-row">
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Partnership analytics</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Objective player ratings</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Fixed partnerships</span>
        <span class="pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Team selection</span>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section>
  <div class="wrap">

    <!-- Partnership analytics (real) -->
    <div class="showcase" style="margin-bottom:64px">
      <div class="copy">
        <div class="step-eyebrow">Partnership analytics</div>
        <h3>Discover which partnerships actually work</h3>
        <p>Every pairing is measured against what their ratings predicted. See who consistently performs better together - and who only looks good on paper.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> A "vs expected" figure for every pair</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Over-performing or under-performing, at a glance</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Confidence based on games played together</li>
        </ul>
        <div class="callout">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
          <p><b>"Over-performing" means a pair regularly beats what their ratings expect.</b> Those are the partnerships worth keeping together for league nights.</p>
        </div>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/partnerships</span></div>
        <img src="/img/partnerships.png" alt="Partnership analytics - pairs and how they perform versus expectation, with verdict and confidence">
      </div>
    </div>

    <!-- Player ratings (real) -->
    <div class="showcase flip" style="margin-bottom:64px">
      <div class="copy">
        <div class="step-eyebrow">Player ratings</div>
        <h3>Ratings you can trust, from real results</h3>
        <p>Every game updates a player's rating based on how they performed against expectation - not just wins and losses. It is the foundation for fair pairings and balanced teams.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Stronger opponents are worth more</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Narrow defeats hurt less than thrashings</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Updates automatically after every game</li>
        </ul>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/members</span></div>
        <img src="/img/ratings.png" alt="A player's rating progression over a season, climbing as results come in">
      </div>
    </div>

    <!-- Fixed partnerships (placeholder) -->
    <div class="showcase" style="margin-bottom:64px">
      <div class="copy">
        <div class="step-eyebrow">Fixed partnerships</div>
        <h3>Keep proven pairings together</h3>
        <p>Found a pair that clicks? Lock them as a unit so they stay together when games are picked - on club nights and in competitions alike.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/members</span></div>
        <div class="ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg><b>Screenshot: Fixed partnerships</b><span>real app screenshot drops in here</span></div>
      </div>
    </div>

    <!-- Team selection (placeholder) -->
    <div class="showcase flip">
      <div class="copy">
        <div class="step-eyebrow">Team selection</div>
        <h3>Pick teams on data, not guesswork</h3>
        <p>Build league line-ups from ratings, partnership performance and recent form - so selection conversations start from evidence everyone can see.</p>
      </div>
      <div class="shot">
        <div class="bar"><span class="dots"><i></i><i></i><i></i></span><span class="url">play.epegboard.com/members</span></div>
        <div class="ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg><b>Screenshot: Team selection</b><span>real app screenshot drops in here</span></div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS FLOW -->
<section class="bg-soft" id="how">
  <div class="wrap">
    <div class="section-head center">
      <span class="eyebrow">How it fits together</span>
      <h2>Every club night makes your team selection smarter</h2>
      <p>The games you already play feed the data that picks better teams - no extra admin.</p>
    </div>
    <div class="flow">
      <div class="node"><b>Club night results</b><small>games you already play</small></div>
      <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      <div class="node"><b>Player ratings</b><small>updated every game</small></div>
      <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      <div class="node"><b>Partnership analytics</b><small>what works together</small></div>
      <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      <div class="node"><b>Fixed partnerships</b><small>keep the best pairs</small></div>
      <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      <div class="node"><b>Team selection</b><small>pick on evidence</small></div>
    </div>
  </div>
</section>

<!-- ENGINE THREAD -->
<section style="padding:48px 0">
  <div class="wrap">
    <div class="engine-strip">
      <div class="es-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M21 7v6h-6"/></svg></div>
      <div class="es-txt">
        <h3>One rating system, the whole platform</h3>
        <p>Team insights run on the same ratings that pick your club-night games and set tournament handicaps - so everything stays consistent and current.</p>
      </div>
      <a class="btn btn-ghost" style="background:#fff" href="/features/club-nights">How ratings work</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Pick your next team on real data</h2>
    <p>Free for 60 days. No card details.</p>
    <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank">Start Free Trial</a>
    <p class="fine">Tablet or laptop-sized screens recommended for the best experience.</p>
  </div>
</section>

