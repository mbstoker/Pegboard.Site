@page
@model PricingModel
@{
    ViewData["Title"] = "Pricing";
}

<h1 class="display-4 mb-4">💳 Pricing</h1>

<section class="py-3">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 border-success">
                <div class="card-body">
                    <h3 class="card-title">Web app <span class="badge bg-success ms-2">Recommended</span></h3>
                    <p class="card-text fs-5"><strong>Free for at least 60 days</strong></p>
                    <p class="card-text text-muted">
                        Sign up at <a href="https://play.epegboard.com" target="_blank" rel="noopener">play.epegboard.com</a> - no card details required.
                    </p>
                    <p class="card-text">
                        Post-trial pricing is being finalised. We'll announce ahead of any change so you have plenty of notice.
                    </p>
                    <a href="https://play.epegboard.com" target="_blank" rel="noopener" class="btn btn-success btn-lg mt-2">Sign Up Free</a>
                    <p class="mt-3 mb-0" style="font-size: 0.9rem;">
                        Tablet or laptop-sized screens recommended for the best experience.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="card-title">Desktop app</h3>
                    <p class="card-text fs-5"><strong>£60 / year per club</strong></p>
                    <p class="card-text text-muted">
                        After a 60-day free trial. No automatic renewal - you choose when to renew. Windows only; runs fully offline once installed.
                    </p>
                    <p class="card-text">
                        Existing desktop clubs remain supported. Most new functionality will be web-only.
                    </p>
                    <a asp-page="/Download" class="btn btn-outline-primary mt-2">Get the desktop app</a>
                </div>
            </div>
        </div>
    </div>
</section>

<hr class="my-5" />

<h3>Buying a desktop licence</h3>
<p class="text-muted">
    To purchase a desktop licence after your trial, drop your details in below and we'll be in touch with payment instructions. (Web-app post-trial sign-up isn't required yet - we'll announce ahead of any change.)
</p>

@if (Model.RequestSent)
{
    <div class="alert alert-success">✅ Thanks! We've received your request and will be in touch shortly.</div>
}
else
{
    <form method="post">
        <div class="mb-3">
            <label asp-for="PurchaseRequest.Name" class="form-label">Your Name</label>
            <input asp-for="PurchaseRequest.Name" class="form-control" />
            <span asp-validation-for="PurchaseRequest.Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="PurchaseRequest.ClubName" class="form-label">Club Name</label>
            <input asp-for="PurchaseRequest.ClubName" class="form-control" />
            <span asp-validation-for="PurchaseRequest.ClubName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="PurchaseRequest.Email" class="form-label">Email</label>
            <input asp-for="PurchaseRequest.Email" type="email" class="form-control" />
            <span asp-validation-for="PurchaseRequest.Email" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Request Purchase Info</button>
    </form>
}
