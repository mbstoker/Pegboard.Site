@page
@model PricingModel
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Pricing - badminton club software";
    ViewData["Description"] = "ePegboard is free for clubs. The full club-night workflow - smart picker, live ratings, scoring, payments, attendance, tournaments, history and reports - free, no card needed.";

    var px = PegboardWebSite.Services.CurrencyResolver.Get(ViewContext.HttpContext);
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner" style="max-width:none">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>Pricing</span></div>
      <h1 style="margin-top:10px">ePegboard is free for your club</h1>
      <p class="lede">The full club-night workflow is <strong>free for every club</strong>, for good - no card needed, no trial countdown. Run your weekly nights on it from day one.</p>
    </div>
  </div>
</section>

<!-- WHAT YOU GET -->
<section style="padding-top:46px">
  <div class="wrap">
    <div style="max-width:1020px;margin:0 auto">
      <div class="price feat" style="padding:34px 36px">
        <h3 style="margin-bottom:4px">Everything, free</h3>
        <div class="price-for" style="margin-bottom:18px">Everything your badminton club needs to run club nights, competitions and your membership.</div>
        <ul class="feats" style="columns:2;column-gap:40px">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Smart game picker</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Live ratings</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Attendance &amp; payments</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Tournaments</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> League tools</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Full reports</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Club branding</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Unlimited club nights</li>
        </ul>
        <div style="text-align:center;margin-top:26px">
          <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank">Sign up</a>
          <p style="color:var(--muted);font-size:.92rem;margin-top:12px">No card. No install. Per club, not per player.</p>
        </div>
      </div>
    </div>

    <!-- LARGER / MULTI-SITE -->
    <p style="text-align:center;color:var(--muted);font-size:.95rem;margin-top:24px;max-width:64ch;margin-left:auto;margin-right:auto">Running a very large or multi-site club, a league, or a one-off competition? <a href="mailto:sales@epegboard.com?subject=ePegboard%20enquiry" style="color:var(--link);font-weight:600">Get in touch</a> and we will sort something out for you.</p>
  </div>
</section>

<!-- WHY FREE -->
<section style="padding-top:46px">
  <div class="wrap">
    <div style="max-width:64ch;margin:0 auto;text-align:center">
      <h2 style="margin-bottom:18px">Why is ePegboard free?</h2>
      <p style="color:var(--muted-2);font-size:1.05rem;margin-bottom:6px">The more clubs that use ePegboard, the more valuable it becomes for everyone.</p>
      <ul style="list-style:none;padding:0;margin:18px 0;color:var(--ink);font-weight:600;font-size:1.1rem;line-height:1.95">
        <li>More inter-club competition</li>
        <li>More shared ideas</li>
        <li>More feedback</li>
        <li>More improvements</li>
      </ul>
      <p style="color:var(--muted-2);font-size:1.05rem;margin-bottom:14px">That's why growing the community is our priority.</p>
      <p style="color:var(--muted-2);font-size:1.05rem;margin-bottom:0">We also know badminton clubs vary enormously in size and budget. We don't believe cost should prevent a club from accessing great club management software, so the platform that runs your club night is free for everyone.</p>
    </div>
  </div>
</section>

<!-- LOOKING AHEAD -->
<section style="padding-top:36px">
  <div class="wrap">
    <div style="max-width:64ch;margin:0 auto;text-align:center">
      <h2 style="margin-bottom:18px">Looking ahead</h2>
      <p style="color:var(--muted-2);font-size:1.05rem;margin-bottom:0">As the network grows, we expect to add optional services for larger clubs, regional organisations and advanced administration. For now the focus is simpler: building the strongest badminton club community we can - and the core platform that runs your club night stays free for every club in it.</p>
    </div>
  </div>
</section>

<!-- COMMUNITY SUPPORTER -->
<section style="padding-top:36px">
  <div class="wrap">
    <div style="max-width:1020px;margin:0 auto;background:var(--bg-tint);border:1px solid var(--line);border-radius:var(--radius);padding:28px 32px;text-align:center">
      <p style="font-weight:700;color:var(--ink);font-size:1.15rem;margin-bottom:8px">Become a Community Supporter</p>
      <p style="color:var(--muted-2);font-size:1.04rem;max-width:66ch;margin:0 auto 14px">If ePegboard brings value to your club, please consider becoming a Community Supporter. Community Supporters help fund:</p>
      <ul style="list-style:none;padding:0;margin:0 auto 16px;color:var(--ink);font-weight:600;font-size:1.02rem;line-height:1.85;display:inline-block;text-align:left">
        <li>New features</li>
        <li>Hosting and infrastructure</li>
        <li>Documentation</li>
        <li>Support</li>
        <li>Outreach to new clubs</li>
      </ul>
      <p style="color:var(--muted-2);font-size:1.04rem;max-width:66ch;margin:0 auto">It is entirely optional - every club gets the full app either way.</p>
    </div>
  </div>
</section>

<!-- DESKTOP APP -->
<section style="padding-top:40px">
  <div class="wrap">
    <div class="engine-strip" style="background:linear-gradient(135deg,#eef3f8,#e4ecf5);color:var(--ink-2)">
      <div class="es-ico" style="background:rgba(27,110,194,.12);color:var(--primary)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
      <div class="es-txt">
        <h3 style="color:var(--ink)">Prefer to run fully offline?</h3>
        <p style="color:var(--muted-2)">The Windows desktop app is @(px.Symbol)@px.DesktopYear a year per club, with a 60-day free trial. The right choice if your venue has unreliable internet. New features land on the web app first.</p>
      </div>
      <a class="btn btn-ghost" href="#">About the desktop app</a>
    </div>
  </div>
</section>

<!-- OUR PROMISES -->
<section class="bg-soft">
  <div class="wrap">
    <div class="section-head center"><span class="eyebrow">Our promises</span><h2>Fair, and honest about it</h2></div>
    <div class="report-grid" style="grid-template-columns:repeat(3,1fr);max-width:820px;margin:0 auto">
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg></span> Free, always</h4>
        <p>The club-night workflow stays free. There will always be a free plan that runs your club night, and it is not going behind a paywall.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span> 60 days' notice</h4>
        <p>At least 60 days' written notice before any pricing change takes effect - to the billing contact and in-app.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span> No card needed</h4>
        <p>Sign up and run real sessions without entering any card details. Nothing to cancel, no countdown.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Start using ePegboard free</h2>
    <p>The full product, no card, no install. See it on a real club night.</p>
    <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank">Sign up</a>
    <p class="fine">Questions about pricing? See the <a href="/faq" style="color:#fff;text-decoration:underline">FAQ</a> or get in touch.</p>
  </div>
</section>

<!-- FOOTER -->
