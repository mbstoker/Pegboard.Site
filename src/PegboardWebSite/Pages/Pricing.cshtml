@page
@model PricingModel
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Pricing - badminton club software";
    ViewData["Description"] = "ePegboard pricing: 60 days of everything free, no card needed. Smaller badminton clubs stay free; busier clubs upgrade as they grow, from around £8 a month.";

    var px = PegboardWebSite.Services.CurrencyResolver.Get(ViewContext.HttpContext);
}

@section Head {
    <style>
      .ccy-toggle { display:inline-flex; gap:2px; padding:3px; border:1px solid var(--line); border-radius:999px; background:#fff; margin-left:8px; vertical-align:middle }
      .ccy-toggle a { padding:5px 14px; border-radius:999px; font-size:.9rem; font-weight:600; color:var(--muted-2); text-decoration:none; line-height:1 }
      .ccy-toggle a.on { background:var(--primary); color:#fff }
      .ccy-note { text-align:center; color:var(--muted); font-size:.95rem; margin-top:20px }
    </style>
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner" style="max-width:none">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>Pricing</span></div>
      <h1 style="margin-top:10px">Pricing that grows with your club</h1>
      <p class="lede">Start with <strong>60 days of everything, free</strong> - no card needed. After that, smaller clubs stay free, and busier clubs upgrade as they grow.</p>
      <p class="ccy-note" style="text-align:left;margin-top:14px">
        Show prices in
        <span class="ccy-toggle">
          <a href="?ccy=gbp" class="@(px.Code == "GBP" ? "on" : "")">GBP £</a>
          <a href="?ccy=aud" class="@(px.Code == "AUD" ? "on" : "")">AUD A$</a>
        </span>
      </p>
    </div>
  </div>
</section>

<!-- TIERS -->
<section style="padding-top:46px">
  <div class="wrap">
    <div class="price-grid cols-3">

      <!-- Free -->
      <div class="price">
        <h3>Free</h3>
        <div class="amt">@(px.Symbol)0 <span class="per">/ forever</span></div>
        <div class="price-for">For smaller and casual clubs</div>
        <ul class="feats">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> One session a week, up to 12 players</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> The full smart picker and live ratings</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Scoring, payments and attendance</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> One club tournament a year</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Last 30 days of history</li>
        </ul>
      </div>

      <!-- Pro (recommended) -->
      <div class="price feat">
        <span class="badge">Most popular</span>
        <h3>Pro</h3>
        <div class="amt">@(px.Symbol)@px.ProMonth <span class="per">/ month</span></div>
        <div class="price-for">or @(px.Symbol)@px.ProYear a year (2 months free) &middot; For established weekly clubs</div>
        <ul class="feats">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <strong>Everything in Free</strong>, plus:</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Two sessions a week, up to 30 players</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Three tournaments a year - pairs, groups, knockouts</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> League team tools - partnerships and selection</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Full history, plus session, payment &amp; member reports</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> CSV export, and your club name and logo</li>
          <li class="muted"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v8M8 12h8"/></svg> Online payment collection (coming soon)</li>
        </ul>
      </div>

      <!-- Premium -->
      <div class="price">
        <h3>Premium</h3>
        <div class="amt">@(px.Symbol)@px.PremiumMonth <span class="per">/ month</span></div>
        <div class="price-for">or @(px.Symbol)@px.PremiumYear a year (2 months free) &middot; For larger clubs</div>
        <ul class="feats">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <strong>Everything in Pro</strong>, plus:</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Up to 6 sessions a week, up to 60 players</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> 12 tournaments a year</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Growth analytics - who's drifting, who to reach out to</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Member engagement and new-member conversion</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Attendance over time - watch the club grow</li>
        </ul>
      </div>

    </div>
    <div style="max-width:1020px;margin:32px auto 0;background:var(--bg-tint);border:1px solid var(--line);border-radius:var(--radius);padding:28px 30px;text-align:center">
      <p style="font-weight:700;color:var(--ink);font-size:1.15rem;margin-bottom:4px">Every plan above starts the same way</p>
      <p style="color:var(--muted-2);font-size:1.02rem;max-width:62ch;margin:0 auto 18px">60 days of full access to everything - free, no card. After that, keep a free plan or move to whichever tier fits how your club plays. Nothing changes without you choosing it.</p>
      <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank">Start your 60-day free trial</a>
    </div>

    <p style="text-align:center;color:var(--muted);font-size:.92rem;margin-top:22px">Per club, not per player. Billed monthly or annually - annual saves 2 months and covers your whole playing season. Bigger than Premium, or just the odd tournament? <a href="mailto:sales@epegboard.com?subject=ePegboard%20pricing%20enquiry" style="color:var(--link);font-weight:600">Talk to us</a> about a custom or per-competition plan.</p>
    @if (px.Indicative)
    {
        <p style="text-align:center;color:var(--muted);font-size:.92rem;margin-top:10px">Prices in @px.Code are indicative, to give Australian clubs a feel for the cost. There's nothing to pay during your 60-day trial, and we'll confirm fair local pricing before you upgrade. Prefer GBP? <a href="?ccy=gbp" style="color:var(--link);font-weight:600">Switch back</a>.</p>
    }
    else
    {
        <p style="text-align:center;color:var(--muted);font-size:.92rem;margin-top:10px">Prices are shown in GBP. In Australia? <a href="?ccy=aud" style="color:var(--link);font-weight:600">See indicative AUD pricing</a>, or <a href="mailto:sales@epegboard.com?subject=ePegboard%20pricing%20enquiry" style="color:var(--link);font-weight:600">get in touch</a> about pricing for your region.</p>
    }
  </div>
</section>

<!-- DESKTOP APP -->
<section style="padding-top:40px">
  <div class="wrap">
    <div class="engine-strip" style="background:linear-gradient(135deg,#eef3f8,#e4ecf5);color:var(--ink-2)">
      <div class="es-ico" style="background:rgba(27,110,194,.12);color:var(--primary)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
      <div class="es-txt">
        <h3 style="color:var(--ink)">Prefer to run fully offline?</h3>
        <p style="color:var(--muted-2)">The Windows desktop app is @(px.Symbol)@px.DesktopYear a year per club, with a 60-day free trial. The right choice if your venue has unreliable internet. New features land on the web app first.</p>
      </div>
      <a class="btn btn-ghost" href="#">About the desktop app</a>
    </div>
  </div>
</section>

<!-- OUR PROMISES -->
<section class="bg-soft">
  <div class="wrap">
    <div class="section-head center"><span class="eyebrow">Our promises</span><h2>Fair, and honest about it</h2></div>
    <div class="report-grid" style="grid-template-columns:repeat(4,1fr);max-width:1020px;margin:0 auto">
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg></span> A free plan, always</h4>
        <p>There will always be a free plan that runs your club night within fair-use limits. It is not going behind a paywall.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span> 60 days' notice</h4>
        <p>At least 60 days' written notice before any pricing change takes effect - to the billing contact and in-app.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span> No card to start</h4>
        <p>Sign up and run real sessions for 60 days without entering any card details. No trial countdown anxiety.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v8a7 7 0 0 0 14 0V3"/><circle cx="12" cy="20" r="1.6" fill="currentColor" stroke="none"/></svg></span> Windows clubs honoured</h4>
        <p>Already on the Windows Pegboard? You keep full access for the rest of your licence, then move onto a standard plan.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Try ePegboard free for 60 days</h2>
    <p>The full product, no card, no install. See it on a real club night.</p>
    <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank">Start your free trial</a>
    <p class="fine">Questions about pricing? See the <a href="/faq" style="color:#fff;text-decoration:underline">FAQ</a> or get in touch.</p>
  </div>
</section>

<!-- FOOTER -->
