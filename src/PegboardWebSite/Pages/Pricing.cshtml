@page
@model PricingModel
@{
    Layout = "_LayoutMarketing";
    ViewData["Title"] = "Pricing - badminton club software";
    ViewData["Description"] = "ePegboard is free for clubs. The full club-night workflow - smart picker, live ratings, scoring, payments, attendance, tournaments, history and reports - free, no card needed.";

    var px = PegboardWebSite.Services.CurrencyResolver.Get(ViewContext.HttpContext);
}

<!-- HERO -->
<section class="page-hero" style="padding:0">
  <div class="wrap">
    <div class="inner" style="max-width:none">
      <div class="crumb"><a href="/">Home</a> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg> <span>Pricing</span></div>
      <h1 style="margin-top:10px">ePegboard is free for your club</h1>
      <p class="lede">The full club-night workflow is <strong>free for every club</strong>, for good - no card needed, no trial countdown. Run your weekly nights on it from day one.</p>
    </div>
  </div>
</section>

<!-- WHAT YOU GET -->
<section style="padding-top:46px">
  <div class="wrap">
    <div style="max-width:1020px;margin:0 auto">
      <div class="price feat" style="padding:34px 36px">
        <h3 style="margin-bottom:4px">Everything, free</h3>
        <div class="price-for" style="margin-bottom:18px">The complete workflow for a normal club night. It suits the vast majority of clubs.</div>
        <ul class="feats" style="columns:2;column-gap:40px">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> The full smart picker - fair, varied games all night</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Live player ratings, updated after every game</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Scoring, payments and attendance</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Club tournaments - pairs, groups and knockouts</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> League team tools - partnerships and selection</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Full history, with session, payment and member reports</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> CSV export, and your club name and logo</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> As many players and sessions as your club night needs</li>
        </ul>
        <div style="text-align:center;margin-top:26px">
          <a class="btn btn-primary btn-lg" href="https://play.epegboard.com/signup" target="_blank">Start using it free</a>
          <p style="color:var(--muted);font-size:.92rem;margin-top:12px">No card. No install. Per club, not per player.</p>
        </div>
      </div>
    </div>

    <!-- COMMUNITY SUPPORT -->
    <div style="max-width:1020px;margin:28px auto 0;background:var(--bg-tint);border:1px solid var(--line);border-radius:var(--radius);padding:26px 30px;text-align:center">
      <p style="font-weight:700;color:var(--ink);font-size:1.1rem;margin-bottom:4px">Community supporters</p>
      <p style="color:var(--muted-2);font-size:1.02rem;max-width:64ch;margin:0 auto">ePegboard is free, and it stays free. If your club values it and wants to help cover the running costs, you can chip in - entirely optional, and it never unlocks anything. Everyone gets the full app either way.</p>
    </div>

    <!-- LARGER / MULTI-SITE -->
    <p style="text-align:center;color:var(--muted);font-size:.95rem;margin-top:24px;max-width:64ch;margin-left:auto;margin-right:auto">Running a very large or multi-site club, a league, or a one-off competition? <a href="mailto:sales@epegboard.com?subject=ePegboard%20enquiry" style="color:var(--link);font-weight:600">Get in touch</a> and we will sort something out for you.</p>
  </div>
</section>

<!-- DESKTOP APP -->
<section style="padding-top:40px">
  <div class="wrap">
    <div class="engine-strip" style="background:linear-gradient(135deg,#eef3f8,#e4ecf5);color:var(--ink-2)">
      <div class="es-ico" style="background:rgba(27,110,194,.12);color:var(--primary)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
      <div class="es-txt">
        <h3 style="color:var(--ink)">Prefer to run fully offline?</h3>
        <p style="color:var(--muted-2)">The Windows desktop app is @(px.Symbol)@px.DesktopYear a year per club, with a 60-day free trial. The right choice if your venue has unreliable internet. New features land on the web app first.</p>
      </div>
      <a class="btn btn-ghost" href="#">About the desktop app</a>
    </div>
  </div>
</section>

<!-- OUR PROMISES -->
<section class="bg-soft">
  <div class="wrap">
    <div class="section-head center"><span class="eyebrow">Our promises</span><h2>Fair, and honest about it</h2></div>
    <div class="report-grid" style="grid-template-columns:repeat(4,1fr);max-width:1020px;margin:0 auto">
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg></span> Free, always</h4>
        <p>The club-night workflow stays free. There will always be a free plan that runs your club night, and it is not going behind a paywall.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span> 60 days' notice</h4>
        <p>At least 60 days' written notice before any pricing change takes effect - to the billing contact and in-app.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span> No card needed</h4>
        <p>Sign up and run real sessions without entering any card details. Nothing to cancel, no countdown.</p>
      </div>
      <div class="report-card">
        <h4><span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v8a7 7 0 0 0 14 0V3"/><circle cx="12" cy="20" r="1.6" fill="currentColor" stroke="none"/></svg></span> Windows clubs honoured</h4>
        <p>Already on the Windows Pegboard? Your licence is honoured in full, and the web app is there for you free whenever you want to move across.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="wrap">
    <h2>Start using ePegboard free</h2>
    <p>The full product, no card, no install. See it on a real club night.</p>
    <a class="btn btn-ghost btn-lg" style="background:#fff" href="https://play.epegboard.com/signup" target="_blank">Get started free</a>
    <p class="fine">Questions about pricing? See the <a href="/faq" style="color:#fff;text-decoration:underline">FAQ</a> or get in touch.</p>
  </div>
</section>

<!-- FOOTER -->
