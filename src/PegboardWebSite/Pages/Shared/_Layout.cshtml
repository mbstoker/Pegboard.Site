<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ePegboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PegboardWebSite.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <img src="~/Images/epegboard-figure-logo.png" height="40" style="align-self:flex-start" />
                    <img src="~/Images/epegboard-text-logo.png" height="40" style="align-self:flex-start" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Features">Features</a>
                        </li>
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-area="" asp-page="/FeaturesDesktop">Desktop app</a>
                        </li>
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Pricing">Pricing</a>
                        </li>
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-area="" asp-page="/FAQs">FAQs</a>
                        </li>
                        <li class="nav-item dropdown mx-2">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="helpDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Help and Support
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="helpDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-page="/ReportBug">Report Bug</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/RequestFeature">Request Feature</a></li>
                                <li><a class="dropdown-item text-dark" href="mailto:support@epegboard.com">Email Support</a></li>
                                <li><a class="dropdown-item text-dark" href="mailto:sales@epegboard.com">Email Sales</a></li>
                                <li><a class="dropdown-item text-dark" href="/downloads/epegboard user guide.pdf" download>Download User Guide (desktop)</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/ReleaseNotes">Release notes / version history</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/ProductRoadmap">Product roadmap</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Download">Desktop app download</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item mx-2">
                            <a class="btn btn-success px-3" href="https://play.epegboard.com/signup" target="_blank" rel="noopener">Sign Up Free</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MBS Software Limited -
            <a asp-area="" asp-page="/Privacy" class="me-3">Privacy</a>
            <a asp-area="" asp-page="/Contact" class="me-3">Contact Us</a>
            <a asp-area="" asp-page="/License">License Terms</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>