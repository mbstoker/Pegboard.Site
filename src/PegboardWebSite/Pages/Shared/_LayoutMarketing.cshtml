@inject IConfiguration Configuration
@{
    var currentYear = DateTime.Now.Year;

    var pageTitle = ViewData["Title"] as string;
    var metaDescription = ViewData["Description"] as string
        ?? "ePegboard runs your badminton club night - fair, balanced games with smart picking, live ratings, attendance and competitions. Free for clubs at play.epegboard.com.";
    var ogTitle = ViewData["OgTitle"] as string
        ?? (string.IsNullOrEmpty(pageTitle) || pageTitle == "Home" ? "ePegboard" : $"{pageTitle} - ePegboard");
    var baseUrl = (Configuration.GetConnectionString("WebsiteUrl") ?? $"{Context.Request.Scheme}://{Context.Request.Host}").TrimEnd('/');
    var canonicalUrl = ViewData["CanonicalUrl"] as string ?? $"{baseUrl}{Context.Request.Path}";
    var ogImage = ViewData["OgImage"] as string ?? $"{baseUrl}/Images/og-image.png";

    // Sitewide Organization entity for search engines / AI crawlers. Per-page JSON-LD
    // (e.g. SoftwareApplication, FAQPage) is injected via the optional "Head" section.
    var orgJsonLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Organization",
        ["name"] = "ePegboard",
        ["legalName"] = "MBS Software Limited",
        ["url"] = "https://www.epegboard.com",
        ["logo"] = "https://www.epegboard.com/Images/epegboard-text-logo.png"
    });

    var path = (Context.Request.Path.Value ?? "/").ToLowerInvariant();
    string Active(string prefix) => (prefix == "/" ? path == "/" : path.StartsWith(prefix)) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(string.IsNullOrEmpty(pageTitle) ? "ePegboard - Smarter club nights. Fairer games." : $"{pageTitle} - ePegboard")</title>
    <meta name="description" content="@metaDescription" />
    <link rel="canonical" href="@canonicalUrl" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ePegboard" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:image" content="@ogImage" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ogTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image" content="@ogImage" />

    <script type="application/ld+json">@Html.Raw(orgJsonLd)</script>
    @await RenderSectionAsync("Head", required: false)

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/marketing.css" asp-append-version="true" />

    <!-- Cloudflare Web Analytics (cookieless, no consent banner needed) -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "fe7d2acd20e2490f80bc03846c0cb1da"}'></script>
    <!-- End Cloudflare Web Analytics -->
</head>
<body>

<header class="nav" id="siteNav">
  <div class="wrap nav-inner">
    <a class="brand" href="/" aria-label="ePegboard home">
      <img class="brand-mark" src="~/Images/epegboard-figure-logo.png" alt="" />
      <img class="brand-word" src="~/Images/epegboard-text-logo.png" alt="ePegboard" />
    </a>
    <nav class="nav-links">
      <a href="/features" class="@Active("/features")">Features</a>
      <a href="/pricing" class="@Active("/pricing")">Pricing</a>
      <div class="nav-dd">
        <button type="button" class="nav-dd-toggle @(Active("/guides"))@(Active("/faq"))" aria-haspopup="true" aria-expanded="false">
          Resources
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="nav-dd-menu">
          <a href="/guides" class="@Active("/guides")">Guides</a>
          <a href="https://docs.epegboard.com" target="_blank" rel="noopener">Docs</a>
          <a href="/faq" class="@Active("/faq")">FAQ</a>
          <a href="/ReleaseNotes">Release notes</a>
        </div>
      </div>
      <a href="/about" class="@Active("/about")">About</a>
    </nav>
    <div class="nav-cta">
      <a class="signin" href="https://play.epegboard.com" target="_blank" rel="noopener">Sign in</a>
      <span class="nav-div navdemo" aria-hidden="true"></span>
      <a class="btn btn-ghost navdemo" href="https://play.epegboard.com/instant-demo" target="_blank" rel="noopener">See it in action</a>
      <a class="btn btn-primary" href="https://play.epegboard.com/signup" target="_blank" rel="noopener">Sign up</a>
    </div>
    <button class="nav-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="mobileNav">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="mobile-nav" id="mobileNav">
    <div class="wrap">
      <a href="/features" class="@Active("/features")">Features</a>
      <a href="/pricing" class="@Active("/pricing")">Pricing</a>
      <span class="mobile-nav-label">Resources</span>
      <a href="/guides" class="@Active("/guides")">Guides</a>
      <a href="https://docs.epegboard.com" target="_blank" rel="noopener">Docs</a>
      <a href="/faq" class="@Active("/faq")">FAQ</a>
      <a href="/ReleaseNotes">Release notes</a>
      <a href="/about" class="@Active("/about")">About</a>
      <a href="https://play.epegboard.com/instant-demo" target="_blank" rel="noopener">See it in action</a>
      <a href="https://play.epegboard.com" target="_blank" rel="noopener">Sign in</a>
    </div>
  </nav>
</header>

<main>
    @RenderBody()
</main>

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-brand"><img src="~/Images/epegboard-figure-logo.png" alt="" style="height:30px;width:auto" /> ePegboard</div>
        <p style="margin-top:14px;max-width:30ch">Smarter club nights and fairer games for badminton clubs.</p>
      </div>
      <div><h5>Product</h5><a href="/features">Features</a><a href="/features/competitions">Competitions</a><a href="/features/league-team-support">League teams</a><a href="/pricing">Pricing</a><a href="/badminton-club-management-software">Badminton club software</a></div>
      <div><h5>Resources</h5><a href="/guides">Guides</a><a href="https://docs.epegboard.com" target="_blank" rel="noopener">Docs</a><a href="/faq">FAQ</a><a href="/ReleaseNotes">Release notes</a><a href="/ProductRoadmap">Product roadmap</a><a href="/FeaturesDesktop">Desktop app</a><a href="/ReportBug">Report a bug</a><a href="/RequestFeature">Request a feature</a></div>
      <div><h5>Company</h5><a href="/about">About</a><a href="/Contact">Contact</a><a href="mailto:sales@epegboard.com">Email sales</a><a href="/Privacy">Privacy</a><a href="/License">License terms</a></div>
    </div>
    <div class="foot-bottom"><span>&copy; @currentYear MBS Software Limited</span><span>play.epegboard.com</span></div>
  </div>
</footer>

<script>
  (function () {
    var nav = document.getElementById('siteNav');
    var btn = nav && nav.querySelector('.nav-toggle');
    if (!nav || !btn) return;
    btn.addEventListener('click', function () {
      var open = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    // Close the menu after tapping a link.
    nav.querySelectorAll('.mobile-nav a').forEach(function (a) {
      a.addEventListener('click', function () {
        nav.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
